{
  "name": "mobile-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "lint:fix": "expo lint --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "jest --coverage",
    "prepare": "husky",
    "build:android:preview": "pnpm eas build --platform android --profile preview",
    "build:android:production": "pnpm eas build --platform android --profile production",
    "build:android:local": "EXPO_PUBLIC_API_URL=https://realdevsquad.com APP_ENV=staging ANDROID_ABI_FILTERS=arm64-v8a pnpm eas build --platform android --profile preview --local"
  },
